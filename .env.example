# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored; `.env.example` is safe to commit.

# Your Firewalla MSP subdomain, e.g. yourname.firewalla.net
FIREWALLA_MSP_DOMAIN=yourname.firewalla.net

# Personal access token from MSP portal → Account Settings → Personal Access Tokens
FIREWALLA_MSP_TOKEN=paste-your-token-here
